{
  "name": "ocx-github-action",
  "version": "1.0.0",
  "description": "OCX Protocol GitHub Action for cryptographic receipt generation",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.js -o dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "clean": "rm -rf dist/ node_modules/",
    "benchmark": "node src/benchmark.js",
    "package": "npm run build && npm pack"
  },
  "keywords": [
    "ocx",
    "protocol",
    "github-action",
    "cryptographic",
    "receipt",
    "verification"
  ],
  "author": "OCX Protocol Team",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0",
    "@actions/artifact": "^1.1.0",
    "axios": "^1.6.0",
    "crypto": "^1.0.1",
    "fs": "^0.0.1-security",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.0",
    "jest": "^29.7.0",
    "eslint": "^8.54.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ocx-protocol/ocx-github-action.git"
  },
  "bugs": {
    "url": "https://github.com/ocx-protocol/ocx-github-action/issues"
  },
  "homepage": "https://github.com/ocx-protocol/ocx-github-action#readme"
}
