# OCX Protocol .gitignore

# OCX large/build artifacts
.ocx/
receipts/
**/target/
node_modules/
*.log
*.tmp
.DS_Store

# local binaries
/ocx
/server
/ocx-server
/api-server
/debug-server
/final-server
/minimal-server
/mock-server
/ocx-complete-demo
/ocx-core-server
/ocx-db-server
/ocx-gpu-test
/ocx-killer-demo
/ocx-old
/ocx-simple-demo
/ocxctl
/working-server
/ultra-minimal-server

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
coverage.html

# Go modules (go.sum must be committed for reproducible builds)
# go.sum — NOT ignored, required by Docker build

# Rust build artifacts (Cargo.lock must be committed for reproducible builds)
# Cargo.lock — NOT ignored, required by Docker build
target/
**/*.rs.bk

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*~

# Test artifacts
test_*.txt
test_*.json
test_*.cbor
*_test.log
*_test.txt

# Database files
*.db
*.sqlite
*.sqlite3

# Log files
*.log
logs/
server.log

# Environment files - NEVER commit these
.env
.env.*
.env.local
.env.*.local
.env.prod
.env.production
.env.development
.env.test

# Backup directories
backup_before_*
*_backup
*_backup_*

# Large archives
*.tar.gz
*.zip
*.rar

# Generated files
generated/
gen_*

# SECURITY - Private keys and secrets (NEVER COMMIT)
*.pem
*.key
!*.pub
*.p12
*.pfx
keys/
secrets/
.secrets/
**/keys/*.pem
**/keys/*.key
ops/keys/
cmd/server/keys/*.pem
cmd/server/keys/*.key
conformance/conformance-keys/*.key

# Keep only public keys and examples
!keys/README.md
!keys/.gitkeep
!.env.example

# Local Netlify folder
.netlify

# Build directories
build/
dist/
out/

# Documentation build artifacts
docs/_build/
docs/.doctrees/
*.pdf.tmp

# Editor configs (keep .editorconfig)
*.sublime-project
*.sublime-workspace

# Coverage reports
*.coverprofile
cover.out
cover.html

# Profiling data
*.prof
*.pprof
cpu.prof
mem.prof

# Benchmarks
benchmark_*.txt
bench.out

# Temporary receipts and test data
/tmp/
*.cbor.tmp
receipt_*.cbor
test_receipt_*

# Local-only docs (never committed; for personal reference)
whitepaper/paper-explained.md
*.local.md
api/.venv/
src.backup-*/
public.backup-*/
api/.env
libocx-verify-wasm/target/
libocx-verify-wasm/pkg/
