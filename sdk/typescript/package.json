{
  "name": "@ocx-protocol/sdk",
  "version": "1.0.0",
  "description": "OCX Protocol SDK for verifiable computation receipts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ocx",
    "verifiable-computation",
    "receipts",
    "blockchain",
    "cryptography",
    "kitaab"
  ],
  "author": "KuroKernel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KuroKernel/ocx-protocol.git"
  },
  "dependencies": {
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
