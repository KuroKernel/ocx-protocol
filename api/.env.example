# ==========================================================================
# OCX API — environment variables
# Copy to .env (gitignored) and fill in real values.
# ==========================================================================

# --- LemonSqueezy (Merchant of Record) ------------------------------------
# Sign up at https://www.lemonsqueezy.com/, complete the OpenKitaab Pvt Ltd
# seller profile, then create three Products with one Variant each:
# OCX Starter ($999/mo), OCX Growth ($4,999/mo), OCX Scale ($9,999/mo).
#
# API key: Settings → API → "Create API Key" (Bearer token; long JWT).
LS_API_KEY=lmnsq_REPLACE_ME

# Store ID: numeric, find at https://app.lemonsqueezy.com/settings/stores
LS_STORE_ID=REPLACE_ME

# Webhook signing secret: Settings → Webhooks → New webhook →
# URL: https://api.ocx.world/v1/webhooks/lemonsqueezy
# Events to subscribe: subscription_created, subscription_updated,
# subscription_cancelled, subscription_resumed, subscription_expired,
# subscription_payment_success, subscription_payment_failed.
# The secret is shown ONCE at create time.
LS_WEBHOOK_SECRET=whsec_REPLACE_ME

# Variant IDs from each Product → Variants tab. Format: numeric string.
LS_VARIANT_STARTER=REPLACE_ME_STARTER
LS_VARIANT_GROWTH=REPLACE_ME_GROWTH
LS_VARIANT_SCALE=REPLACE_ME_SCALE

# --- App ------------------------------------------------------------------
APP_URL=https://ocx.world
SUCCESS_PATH=/welcome
CANCEL_PATH=/pricing

# --- Database -------------------------------------------------------------
# On Railway, auto-injected as DATABASE_URL by the Postgres plugin.
# For local dev: docker run -d --name ocx-pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16
DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/ocx

# --- Email ----------------------------------------------------------------
# Leave POSTMARK_TOKEN empty to log emails to stdout instead of sending.
POSTMARK_TOKEN=
POSTMARK_FROM_EMAIL=hello@ocx.world

# --- Verifier (optional) --------------------------------------------------
# Path to compiled libocx-verify shared library.
OCX_VERIFY_LIB=/opt/ocx/liblibocx_verify.so

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=info
