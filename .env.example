# OCX Protocol - USDC Settlement Configuration

# ===== BLOCKCHAIN CONFIGURATION =====
# Polygon RPC URL (mainnet)
OCX_POLYGON_RPC_URL=https://polygon-rpc.com

# Ethereum RPC URL (for fallback)
OCX_ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-project-id

# Chain ID (137 = Polygon mainnet, 1 = Ethereum mainnet)
OCX_CHAIN_ID=137

# ===== CONTRACT ADDRESSES =====
# USDC contract address on Polygon
OCX_USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# OCX Escrow contract address (deploy this first)
OCX_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ===== SECURITY =====
# Private key for settlement transactions (KEEP SECRET!)
OCX_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ===== FEE CONFIGURATION =====
# Protocol fee in basis points (250 = 2.5%)
OCX_PROTOCOL_FEE_BPS=250

# Arbitration fee in basis points (100 = 1.0%)
OCX_ARBITRATION_FEE_BPS=100

# ===== BLOCKCHAIN PARAMETERS =====
# Number of confirmations required
OCX_CONFIRMATION_BLOCKS=12

# Maximum gas price in wei (100 gwei)
OCX_MAX_GAS_PRICE=100000000000

# Gas limit for transactions
OCX_GAS_LIMIT=200000

# ===== DISPUTE RESOLUTION =====
# Dispute timeout in hours (72 = 3 days)
OCX_DISPUTE_TIMEOUT_HOURS=72

# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection string
OCX_DB=postgres://ocx_user:password@localhost:5432/ocx_protocol

# ===== API CONFIGURATION =====
# OCX API port
OCX_PORT=8080

# Require signatures for API calls (true for production)
OCX_REQUIRE_SIG=true

# ===== LOGGING =====
# Log level (debug, info, warn, error)
OCX_LOG_LEVEL=info

# ===== MONITORING =====
# Enable metrics endpoint
OCX_METRICS_ENABLED=true

# Metrics port
OCX_METRICS_PORT=9090
