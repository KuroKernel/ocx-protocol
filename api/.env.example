# ==========================================================================
# OCX API — environment variables
# Copy to .env (gitignored) and fill in real values.
# ==========================================================================

# --- Stripe ---------------------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Get from https://dashboard.stripe.com/webhooks after creating the endpoint.
# For local dev, run `stripe listen --forward-to localhost:8000/v1/webhooks/stripe`
# and paste the whsec_... it prints.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs from Stripe Dashboard → Products. Format: price_xxxxx
STRIPE_PRICE_STARTER=price_REPLACE_ME_STARTER
STRIPE_PRICE_GROWTH=price_REPLACE_ME_GROWTH
STRIPE_PRICE_SCALE=price_REPLACE_ME_SCALE

# --- App ------------------------------------------------------------------
# URL the user is sent to AFTER paying (success) or cancelling
APP_URL=https://ocx.world
SUCCESS_PATH=/welcome
CANCEL_PATH=/pricing

# --- Database -------------------------------------------------------------
# On Railway, this is auto-injected as DATABASE_URL by the Postgres plugin.
# For local dev, run `docker run -d --name ocx-pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16`
DATABASE_URL=postgresql+psycopg://postgres:dev@localhost:5432/ocx

# --- Email ----------------------------------------------------------------
# Postmark is recommended; sendgrid/SES/etc. all work with small adapter changes.
# Leave POSTMARK_TOKEN empty to log emails to stdout instead of sending.
POSTMARK_TOKEN=
POSTMARK_FROM_EMAIL=hello@ocx.world

# --- Verifier (optional) --------------------------------------------------
# Path to compiled libocx-verify shared library. If unset, /v1/verify
# returns 503. Built by the Dockerfile multi-stage step.
OCX_VERIFY_LIB=/opt/ocx/liblibocx_verify.so

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=info
