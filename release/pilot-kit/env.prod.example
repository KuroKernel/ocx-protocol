# OCX Protocol Production Environment Variables
# Copy this file to .env.prod and update the values

# Database Configuration
OCX_DB_PASSWORD=your_secure_database_password_here

# API Configuration
OCX_API_KEYS=admin:supersecretkey,user1:user1key,user2:user2key

# Grafana Configuration
GRAFANA_PASSWORD=your_grafana_admin_password_here

# SSL/TLS Configuration (optional)
# OCX_TLS_CERT_PATH=/app/certs/server.crt
# OCX_TLS_KEY_PATH=/app/certs/server.key

# Monitoring Configuration
OCX_METRICS_ENABLED=true
OCX_LOG_LEVEL=info
OCX_LOG_FORMAT=json

# Performance Configuration
OCX_RATE_LIMIT_RPS=1000
OCX_RATE_LIMIT_BURST=100
OCX_REQUEST_TIMEOUT=30s
OCX_BODY_SIZE_LIMIT=1048576

# Artifact Cache Configuration
OCX_ARTIFACT_CACHE_SIZE_GB=10
OCX_ARTIFACT_CACHE_TTL=24h

# Deterministic VM Configuration
OCX_VM_TIMEOUT=30s
OCX_VM_MEMORY_LIMIT=67108864
OCX_VM_CYCLE_LIMIT=1000000
